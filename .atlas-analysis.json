  "keyFeatures": [
    "Daily player shop with skin offers and countdown timer",
    "Night Market with discounted skin offers",
    "Current bundles display with skin previews",
    "Skin gallery with browsing and video previews",
    "Wishlist with push notifications when wished skins appear in shop",
    "Player inventory and equipped loadout viewer",
    "Account info with VP/RP/Kingdom Credits balance",
    "Background refresh via WorkManager for store renewal notifications",
    "Firebase-backed wishlist sync across sessions"
  ],
  "publicApiSurface": [
